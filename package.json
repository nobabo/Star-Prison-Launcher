{
  "name": "star-prison-tauri",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
  "scripts": {
    "version:sync": "node sync-package-version.mjs",
    "predev": "pnpm version:sync",
    "dev": "tauri dev",
    "dev:no-port": "cargo run --manifest-path src-tauri/Cargo.toml",
    "prebuild": "pnpm version:sync",
    "build": "tauri build",
    "pretauri": "pnpm version:sync",
    "tauri": "tauri",
    "wiki:dev": "pnpm --filter @star-prison/wiki-web dev",
    "wiki:dev:web": "pnpm --filter @star-prison/wiki-web dev:web",
    "wiki:dev:server": "pnpm --filter @star-prison/wiki-web dev:server",
    "wiki:build": "pnpm --filter @star-prison/wiki-web build",
    "wiki:test": "pnpm --filter @star-prison/wiki-web test",
    "distribution:sync:release": "pnpm version:sync && node .github/scripts/sync-modpack-manifest.mjs && node .github/scripts/sync-release-archives.mjs",
    "lint": "pnpm lint:js && pnpm lint:css",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier \"*.config.js\" \"package.json\" \"pnpm-workspace.yaml\" \".github/workflows/*.yml\" --write",
    "format:check": "prettier \"*.config.js\" \"package.json\" \"pnpm-workspace.yaml\" \".github/workflows/*.yml\" --check",
    "distribution:sync:modpack": "node .github/scripts/sync-modpack-manifest.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "2.11.2",
    "eslint": "^10.4.1",
    "extract-zip": "^2.0.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "yazl": "^3.3.1"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.0"
  }
}
